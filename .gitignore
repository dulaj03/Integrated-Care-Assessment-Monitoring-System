# ================================
# Dependencies (ignore everywhere)
# ================================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ================================
# Build / Output
# ================================
build/
dist/
coverage/
storybook-static/

# ================================
# Environment variables (secrets)
# ================================
.env
.env.*
!.env.example

# ================================
# Logs
# ================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ================================
# Runtime data
# ================================
pids
*.pid
*.seed
*.pid.lock

# ================================
# IDE / Editor
# ================================

.idea/
*.swp
*.swo
*~

# ================================
# OS generated files
# ================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ================================
# Tool caches
# ================================
.eslintcache
.stylelintcache
.node_repl_history
.npm
*.tgz

# ================================
# Config files (optional)
# ================================
.eslintrc.js
.stylelintrc.js
.prettierrc.js

# ================================
# Yarn Berry (keep required files)
# ================================
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
